# ──────────────────────────────────────────────────────────────
# ShadchanAI — PRODUCTION environment (Railway)
#
# Set these as Railway service variables. Do NOT commit real values.
# Every var is validated at boot by server/src/config/env.ts; bad or
# missing values fail the deploy loudly (this is intentional).
# ──────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────
NODE_ENV=production
# Railway injects PORT; the server reads it. Leave unset to use Railway's.
# PORT=3000

# ── Database (MongoDB Atlas — dedicated pilot cluster) ─────────
# Use SRV + auth + a DB name. NOT a shared dev DB.
MONGODB_URI=mongodb+srv://USER:PASS@cluster.xxxx.mongodb.net/shadchanai?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────────
# MUST be >= 32 chars in production (enforced). Generate:
#   openssl rand -hex 32
JWT_SECRET=__GENERATE_64_HEX_CHARS__
JWT_EXPIRES_IN=7d

# ── Security / CORS ───────────────────────────────────────────
# Same-origin deploy: this is your Railway public URL. MUST NOT contain
# localhost in production (enforced). With the SPA served by Express the
# client and API share this origin, so usually just the one entry.
CORS_ORIGINS=https://YOUR-APP.up.railway.app
# Dev-only header auth MUST be false in production (enforced hard-fail).
AUTH_DEV_HEADER_ALLOWED=false
BODY_LIMIT=2mb

# Express serves the built client from here (baked into the image).
CLIENT_DIST_DIR=/app/client/dist

# ── WhatsApp (Baileys) ────────────────────────────────────────
# MUST point at a mounted Railway Volume. These files ARE the WhatsApp
# credentials — losing the volume = re-pairing every channel by QR.
WA_SESSIONS_DIR=/data/wa-sessions
# Single-instance pilot: fine. For >1 replica this MUST be false.
WA_AUTO_START_SESSIONS=true
# Stable id so a restarted process reclaims its own channel locks fast.
WA_INSTANCE_ID=shadchanai-prod-1
# Encrypts on-disk Baileys state. 64 hex chars (openssl rand -hex 32).
# Store this OUTSIDE the volume (e.g. Railway var only).
WA_SESSION_ENCRYPTION_KEY=__GENERATE_64_HEX_CHARS__

# ── PRE-PILOT SAFETY GATES ────────────────────────────────────
# Master kill-switch for ANY real WhatsApp outbound. Keep FALSE until
# you have verified pairing + ingestion end-to-end. Flip to true only
# when operators are ready to send real proposals.
ENABLE_OUTBOUND_MESSAGES=false
# Only ingest from conversations explicitly mapped as profiles_source.
REQUIRE_EXPLICIT_SOURCE_MAPPING=true

# ── AI providers (at least one key required unless AI_DISABLED) ─
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
FALLBACK_PROVIDER=openai
FALLBACK_API_KEY=
FALLBACK_MODEL=gpt-4o-mini
FALLBACK_BASE_URL=https://api.openai.com/v1
# Set true ONLY to run without AI (degraded extraction + advisory).
AI_DISABLED=false

# ── Embeddings (optional; keep disabled until Atlas vector index ready)
EMBEDDINGS_ENABLED=false

# ── Rate limits (per IP per minute) ───────────────────────────
RATE_LIMIT_AI_PER_MIN=20
RATE_LIMIT_AUTH_PER_MIN=10
RATE_LIMIT_DEFAULT_PER_MIN=300

# ── WhatsApp send throttles ───────────────────────────────────
WA_SEND_PER_CHANNEL_PER_MIN=20
WA_SEND_PER_USER_PER_MIN=30
WA_RECONNECT_MAX_ATTEMPTS=10

# ── Logging / audit ───────────────────────────────────────────
LOG_LEVEL=info
STRICT_AUDIT=false
