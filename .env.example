# ──────────────────────────────────────────────
# ShadchanAI Environment Variables
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/shadchanai

# JWT Auth
# In production this MUST be at least 32 random characters.
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Security / CORS
CORS_ORIGINS=http://localhost:5173
# Dev-only: accept X-Dev-User header as auth. NEVER enable in production.
AUTH_DEV_HEADER_ALLOWED=true
BODY_LIMIT=2mb

# Rate limits (requests per minute)
RATE_LIMIT_AI_PER_MIN=20
RATE_LIMIT_AUTH_PER_MIN=10
RATE_LIMIT_DEFAULT_PER_MIN=300

# Logging
LOG_LEVEL=info

# Groq AI Provider (primary)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Fallback AI Provider (OpenAI-compatible)
FALLBACK_PROVIDER=openai
FALLBACK_API_KEY=
FALLBACK_MODEL=gpt-4o-mini
FALLBACK_BASE_URL=https://api.openai.com/v1

# WhatsApp (Baileys — session-based, no webhooks, no Meta Cloud API)
# Each channel stores its Baileys auth state at WA_SESSIONS_DIR/<channelId>/.
# The session directory IS the credential: never commit, exclude from logs,
# use file permissions 0600, encrypt backups at rest.
WA_SESSIONS_DIR=./data/wa-sessions

# Optional display-name defaults (only used by seed scripts; runtime
# channel creation supplies the display name explicitly).
WA_PROFILES_SOURCE_DISPLAY_NAME=
WA_MATCH_SENDING_DISPLAY_NAME=

# On boot: auto-start Baileys sessions for every active channel.
# Must be false for multi-instance deployments (see deployment notes).
WA_AUTO_START_SESSIONS=true

# Embeddings (optional)
EMBEDDINGS_PROVIDER=
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=
