# ──────────────────────────────────────────────
# ShadchanAI Environment Variables
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/shadchanai

# JWT Auth
# In production this MUST be at least 32 random characters.
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Security / CORS
CORS_ORIGINS=http://localhost:5175
# Dev-only: accept X-Dev-User header as auth. NEVER enable in production.
AUTH_DEV_HEADER_ALLOWED=true
BODY_LIMIT=2mb

# Rate limits (requests per minute)
RATE_LIMIT_AI_PER_MIN=20
RATE_LIMIT_AUTH_PER_MIN=10
RATE_LIMIT_DEFAULT_PER_MIN=300

# Logging
LOG_LEVEL=info

# Which engine is PRIMARY: 'groq' (free) or 'openai' (paid). Default groq.
# The other engine auto-serves as the fallback when it has a key.
AI_ENGINE=groq

# Groq AI (free tier)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Fail fast on Groq so a hung/rate-limited primary hands off in seconds.
GROQ_TIMEOUT_MS=12000
GROQ_MAX_RETRIES=1

# OpenAI (paid engine) — set OPENAI_API_KEY to your OpenAI key (sk-...).
# `OPENAI` is accepted as an alias for the key. Pick the model too.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_MS=25000
OPENAI_MAX_RETRIES=1

# Legacy fallback vars (still read as a last-resort OpenAI key for back-compat)
FALLBACK_PROVIDER=openai
FALLBACK_API_KEY=
FALLBACK_MODEL=gpt-4o-mini
FALLBACK_BASE_URL=https://api.openai.com/v1

# WhatsApp (Baileys — session-based, no webhooks, no Meta Cloud API)
# Each channel stores its Baileys auth state at WA_SESSIONS_DIR/<channelId>/.
# The session directory IS the credential: never commit, exclude from logs,
# use file permissions 0600, encrypt backups at rest.
WA_SESSIONS_DIR=./data/wa-sessions

# Optional display-name defaults (only used by seed scripts; runtime
# channel creation supplies the display name explicitly).
WA_PROFILES_SOURCE_DISPLAY_NAME=
WA_MATCH_SENDING_DISPLAY_NAME=

# On boot: auto-start Baileys sessions for every active channel.
# Must be false for multi-instance deployments (see deployment notes).
WA_AUTO_START_SESSIONS=true

# Connection watchdog: periodically revive sessions that dropped and stopped
# reconnecting on their own (circuit tripped, or client missing after restart).
# Keeps sessions online without cycling healthy ones. Single-instance only.
WA_WATCHDOG_ENABLED=true
WA_WATCHDOG_INTERVAL_MS=120000

# Embeddings (optional)
EMBEDDINGS_PROVIDER=
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=
